# Renombrá este archivo a .env.local antes de correr `pnpm dev`.
# La app no necesita ninguna API key paga para funcionar.

# Supabase — opcional (sin esto la app corre, pero no persiste resultados)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxx

# URL pública (opcional)
NEXT_PUBLIC_APP_URL=http://localhost:3000
